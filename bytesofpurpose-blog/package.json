{
  "name": "bytesofpurpose-blog",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "generate-changelog": "node scripts/generate-changelog-data.js",
    "generate-ideas": "node scripts/generate-ideas-data.js",
    "generate-logo-variants": "node scripts/generate-logo-variants-data.js",
