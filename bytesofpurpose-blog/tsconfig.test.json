{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["jest", "node"],
    // ts-jest transforms .tsx test files with this config; the Docusaurus base
    // tsconfig is not reliably picked up for JSX emit under ts-jest, so set it
    // explicitly (the automatic runtime needs no React import in scope).
    "jsx": "react-jsx",
    "esModuleInterop": true
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/test/**/*.ts"
  ]
}

