# Dependencies
/node_modules

# Production — Docusaurus build output (default `build/`, plus alternate
# --out-dir targets like `build-support/`).
/build*

# Generated files
.docusaurus
.cache-loader

# Misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*
# npm lock file (using yarn instead)
package-lock.json

# Test coverage
coverage/
.nyc_output/
# Playwright
/test-results/
/playwright-report/
/playwright/.cache/
test/e2e/screenshots/*.png
!test/e2e/screenshots/.gitkeep
# HTML report is saved to test-results/html-report (view offline)

*storybook.log
storybook-static

# Generated changelog data
src/components/Changelog/changelog-data.json

# Generated logo-variant SVG data (build artifact; source: src/lib/binary-pyramid-logo.js)
designs/_binary-pyramid-variants.js

# Rosette-of-zeros scratch working dir from the bikar/qiyas CLIs. We KEEP the final
# recipe (rosette-zeros.igp) for reproducibility but ignore the scratch iterations and
# raw renders. NB: unlike _binary-pyramid-variants.js above, _rosette-zeros-variants.js
# is COMMITTED source (raw output of the private bikar CLI — not regenerable at build).
designs/_rosette-zeros/*
!designs/_rosette-zeros/rosette-zeros.igp

# Generated changelog pages (copied from changelog/ directory)
src/pages/changelog/

# Premium encrypted sidecars are build output (regenerated by rehype-premium-encrypt at build)
static/premium/
