# Prod only — dev mode needs no .env (defaults in docker-compose.dev.yml)
DOMAIN=yourdomain.com
TUNNEL_TOKEN=your-tunnel-token
ANTHROPIC_API_KEY=sk-ant-...
CF_API_TOKEN=your-cloudflare-api-token  # Profile → API Tokens → Custom Token (Zone:DNS:Edit, Account:Tunnel:Edit, Account:Access:Edit)
UMAMI_DB_PASS=changeme       # Auto-generate with: openssl rand -hex 24
UMAMI_SECRET=changeme        # Auto-generate with: openssl rand -hex 24
UMAMI_ADMIN_PASS=changeme    # Set after first Umami login (default: admin/umami)
MCP_OAUTH_CLIENT_ID=your-client-id          # Generate with: make mcp-generate-creds
MCP_OAUTH_CLIENT_SECRET=your-client-secret   # Generate with: make mcp-generate-creds
GOOGLE_PLACES_API_KEY=your-google-places-api-key  # Google Cloud Console → APIs & Services → Credentials
MCP_DB_PASS=changeme                              # Auto-generate with: openssl rand -hex 24
GOOGLE_PLACES_MONTHLY_PRO=5000                     # Monthly quota for Pro tier (basic detail_level)
GOOGLE_PLACES_MONTHLY_ENTERPRISE=1000              # Monthly quota for Enterprise tier (standard/detailed)
QUIP_ACCESS_TOKEN=                                    # Personal access token from https://quip.com/dev/token
STUDIO_HOST=studio.local
ART_PATH=~/Dropbox/art-htmls
BLUEPRINTS_PATH=~/Workspace/git/blueprints
